{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opensport.local/schemas/session_manifest.schema.json",
  "title": "OpenSport IMU session manifest",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "protocol_version", "date", "session_id", "subject_id", "collector_id", "app_version", "trials"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "protocol_version": {"type": "string", "minLength": 1},
    "date": {"type": "string", "format": "date"},
    "session_id": {"type": "string", "minLength": 1},
    "subject_id": {"pattern": "^S[0-9]{3,}$"},
    "collector_id": {"type": "string", "minLength": 1},
    "app_version": {"type": "string", "minLength": 1},
    "trials": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["trial_id", "label_file", "streams"],
        "properties": {
          "trial_id": {"pattern": "^T[0-9]{4,}$"},
          "label_file": {"type": "string"},
          "replaces_trial_id": {"type": ["string", "null"]},
          "streams": {
            "type": "array",
            "minItems": 1,
            "maxItems": 2,
            "items": {
              "type": "object",
              "required": [
                "device_id", "ear_side", "csv_file", "sha256",
                "sample_rate_configured_hz", "acceleration_unit",
                "angular_velocity_unit", "acceleration_range",
                "angular_velocity_range", "filter_config", "firmware_version"
              ],
              "properties": {
                "device_id": {"pattern": "^D[0-9]{2,}$"},
                "ear_side": {"enum": ["left", "right"]},
                "csv_file": {"type": "string"},
                "sha256": {"pattern": "^[a-fA-F0-9]{64}$"},
                "sample_rate_configured_hz": {"type": "number", "exclusiveMinimum": 0},
                "acceleration_unit": {"enum": ["m/s2", "m/s²", "g"]},
                "angular_velocity_unit": {"enum": ["rad/s", "deg/s", "°/s"]},
                "acceleration_range": {"type": "number", "exclusiveMinimum": 0},
                "angular_velocity_range": {"type": "number", "exclusiveMinimum": 0},
                "filter_config": {"type": "string", "minLength": 1},
                "firmware_version": {"type": "string", "minLength": 1},
                "axis_sign": {
                  "type": "array",
                  "prefixItems": [{"enum": [-1, 1]}, {"enum": [-1, 1]}, {"enum": [-1, 1]}],
                  "minItems": 3,
                  "maxItems": 3
                }
              }
            }
          }
        }
      }
    }
  }
}
