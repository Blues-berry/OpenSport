{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opensport.local/schemas/quality_report.schema.json",
  "title": "OpenSport IMU quality report",
  "type": "object",
  "required": ["schema_version", "session_id", "trial_id", "status", "evidence_tier", "streams", "issues"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "status": {"enum": ["accepted", "accepted_with_note", "recollect_required"]},
    "evidence_tier": {"enum": ["gold", "legacy_reviewed", "session_weak", "rejected"]},
    "streams": {"type": "array", "minItems": 1}
  }
}
